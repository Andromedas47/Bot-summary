# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose to the browser. Used by the webhook handler.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── LINE Messaging API ───────────────────────────────────────────────────────
# Found in: LINE Developers console → your channel → Basic settings
LINE_CHANNEL_SECRET=your-channel-secret-here

# Optional: needed only if you send reply/push messages
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token-here

# OpenAI vision extraction for Phase 2 slip checks
OPENAI_API_KEY=your-openai-api-key-here
SLIP_EXTRACTION_MODEL=gpt-4o-mini

# Protected cron routes, including the external Release B produce finalizer.
# Release B does not create a scheduler; configure a durable caller separately.
CRON_SECRET=your-random-cron-secret

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Logging ──────────────────────────────────────────────────────────────────
# Options: debug | info | warn | error  (default: debug in dev, info in prod)
LOG_LEVEL=info
